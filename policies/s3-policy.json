{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowReadObjectsFromBucket",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:GetObjectVersion"
      ],
      "Resource": "arn:aws:s3:::tarefas-automatizadas-dev-bucket/*"
    },
    {
      "Sid": "AllowListBucket",
      "Effect": "Allow",
      "Action": [
        "s3:ListBucket"
      ],
      "Resource": "arn:aws:s3:::tarefas-automatizadas-dev-bucket"
    },
    {
      "Sid": "AllowGetBucketLocation",
      "Effect": "Allow",
      "Action": [
        "s3:GetBucketLocation"
      ],
      "Resource": "arn:aws:s3:::tarefas-automatizadas-dev-bucket"
    }
  ]
}
